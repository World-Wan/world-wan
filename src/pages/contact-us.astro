---
import Layout from '../layouts/Layout.astro';
---

<Layout title="聯絡我們" description="聯絡沃原科技，提供專業網路、通訊、電力整合服務諮詢。">
  <!-- Hero -->
  <section class="bg-[#0F74BA] text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl sm:text-4xl font-bold mb-3">聯絡我們</h1>
      <p class="text-blue-100">歡迎洽詢，我們將盡快與您聯繫</p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Contact Info -->
      <div>
        <h2 class="text-2xl font-bold text-gray-900 mb-8">聯絡資訊</h2>
        <ul class="space-y-6">
          <li class="flex items-start gap-4">
            <div class="w-10 h-10 bg-blue-50 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-[#0F74BA]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900">地址</p>
              <p class="text-gray-600 mt-1">台中市西區臺灣大道二段285號4樓之2</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="w-10 h-10 bg-blue-50 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-[#0F74BA]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900">電話</p>
              <p class="text-gray-600 mt-1">
                <a href="tel:0423210735" class="hover:text-[#0F74BA]">(04)2321-0735</a>
                ／
                <a href="tel:0423210734" class="hover:text-[#0F74BA]">(04)2321-0734</a>
              </p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="w-10 h-10 bg-blue-50 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-[#0F74BA]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900">Email</p>
              <a href="mailto:Service@world-wan.com.tw" class="text-[#0F74BA] hover:underline mt-1 block">
                Service@world-wan.com.tw
              </a>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="w-10 h-10 bg-blue-50 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-[#0F74BA]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900">Facebook</p>
              <a
                href="https://www.facebook.com/profile.php?id=61552246295157"
                target="_blank"
                rel="noopener noreferrer"
                class="text-[#0F74BA] hover:underline mt-1 block"
              >
                沃原科技 Facebook 粉絲頁
              </a>
            </div>
          </li>
        </ul>

        <!-- Google Map -->
        <div class="mt-8 rounded-xl overflow-hidden border border-gray-200 h-64">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3640.4!2d120.6628!3d24.1469!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2z5Y-w5Lit5biC6KW_5Y6a5Y-w5Lit5biC6KW_5Y6a!5e0!3m2!1szh-TW!2stw!4v1234567890"
            width="100%"
            height="100%"
            style="border:0"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="沃原科技地圖"
          ></iframe>
        </div>
      </div>

      <!-- Tally Form -->
      <div>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">填寫諮詢表單</h2>
        <p class="text-gray-500 mb-6 text-sm">請填寫以下表單，我們的專業團隊將於一個工作日內與您聯繫。</p>
        <!-- TODO: 將以下 iframe src 換成您的 Tally 表單連結 -->
        <!-- 到 https://tally.so 建立免費表單，取得嵌入連結後貼在這裡 -->
        <div class="bg-gray-50 border-2 border-dashed border-gray-300 rounded-xl p-8 text-center">
          <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <p class="text-gray-500 font-medium">Tally 諮詢表單</p>
          <p class="text-gray-400 text-sm mt-2">請前往 tally.so 建立表單後，將嵌入碼貼入此處</p>
          <a
            href="https://tally.so"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block mt-4 px-4 py-2 bg-[#0F74BA] text-white rounded-lg text-sm hover:bg-blue-700 transition-colors"
          >
            前往建立表單
          </a>
        </div>
        <!-- 建立表單後，刪除上面的 div，換成下方 iframe（調整 src）：
        <iframe
          data-tally-src="https://tally.so/embed/YOUR_FORM_ID?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
          loading="lazy"
          width="100%"
          height="500"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          title="聯絡我們"
        ></iframe>
        <script async src="https://tally.so/widgets/embed.js"></script>
        -->
      </div>
    </div>
  </section>
</Layout>
