---
import Layout from './Layout.astro';

interface Props {
  title: string;
  date: Date;
  description?: string;
  category: 'news' | 'domain';
  image?: string;
}

const { title, date, description, category, image } = Astro.props;
const categoryLabel = category === 'news' ? '最新消息' : '產業知識';
const categoryHref = category === 'news' ? '/category/news' : '/category/domain';
const formattedDate = date.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title={title} description={description} image={image}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6 flex items-center gap-2">
      <a href="/" class="hover:text-[#0F74BA]">首頁</a>
      <span>›</span>
      <a href="/our-blog" class="hover:text-[#0F74BA]">最新消息</a>
      <span>›</span>
      <a href={categoryHref} class="hover:text-[#0F74BA]">{categoryLabel}</a>
    </nav>

    <!-- Article header -->
    <header class="mb-8">
      <a
        href={categoryHref}
        class="inline-block px-3 py-1 text-xs font-medium rounded-full mb-4"
        style={category === 'news' ? 'background:#0F74BA;color:#fff' : 'background:#8DC740;color:#fff'}
      >
        {categoryLabel}
      </a>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 leading-tight mb-4">{title}</h1>
      <div class="flex items-center gap-3 text-sm text-gray-500">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
    </header>

    {image && (
      <div class="mb-8 rounded-xl overflow-hidden">
        <img src={image} alt={title} class="w-full h-64 object-cover" />
      </div>
    )}

    <!-- Article content -->
    <div class="prose max-w-none">
      <slot />
    </div>

    <!-- Footer nav -->
    <div class="mt-12 pt-8 border-t border-gray-200 flex justify-between items-center">
      <a href="/our-blog" class="inline-flex items-center gap-2 text-[#0F74BA] hover:underline text-sm font-medium">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        返回最新消息
      </a>
      <a href="/contact-us" class="px-5 py-2 bg-[#F2830A] text-white rounded-full text-sm font-medium hover:bg-orange-600 transition-colors">
        聯絡我們
      </a>
    </div>
  </article>
</Layout>
