---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((p) => p.data.category === 'news')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function postUrl(post: any) {
  const d = post.data.date;
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  const slug = post.data.urlSlug ?? post.id;
  return `/${y}/${m}/${day}/${slug}/`;
}
---

<Layout title="最新消息" description="沃原科技最新公司動態與消息">
  <section class="bg-[#0F74BA] text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl sm:text-4xl font-bold mb-3">最新消息</h1>
      <p class="text-blue-100">掌握沃原最新動態</p>
    </div>
  </section>

  <section class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex gap-4">
      <a href="/our-blog" class="px-4 py-2 bg-white border border-gray-300 text-gray-600 rounded-full text-sm font-medium hover:border-[#0F74BA] hover:text-[#0F74BA] transition-colors">全部</a>
      <a href="/category/news" class="px-4 py-2 bg-[#0F74BA] text-white rounded-full text-sm font-medium">最新消息</a>
      <a href="/category/domain" class="px-4 py-2 bg-white border border-gray-300 text-gray-600 rounded-full text-sm font-medium hover:border-[#8DC740] hover:text-[#8DC740] transition-colors">產業知識</a>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => (
        <article class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
          {post.data.image && (
            <a href={postUrl(post)}>
              <img src={post.data.image} alt={post.data.title} class="w-full h-44 object-cover" />
            </a>
          )}
          <div class="p-5">
            <time class="text-xs text-gray-400">
              {post.data.date.toLocaleDateString('zh-TW', { year: 'numeric', month: '2-digit', day: '2-digit' })}
            </time>
            <h2 class="font-semibold text-gray-900 mt-2 mb-2 leading-snug line-clamp-2">
              <a href={postUrl(post)} class="hover:text-[#0F74BA] transition-colors">{post.data.title}</a>
            </h2>
            {post.data.description && (
              <p class="text-sm text-gray-500 line-clamp-2">{post.data.description}</p>
            )}
            <a href={postUrl(post)} class="inline-block mt-4 text-sm text-[#0F74BA] hover:underline font-medium">閱讀更多 →</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
