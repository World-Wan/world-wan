---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function postUrl(post: any) {
  const d = post.data.date;
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  const slug = post.data.urlSlug ?? post.id;
  return `/${y}/${m}/${day}/${slug}/`;
}
---

<Layout title="首頁" description="沃原科技提供專業整合、網路服務、通訊多媒體、電力工程等全方位科技服務，深耕台灣科技整合領域。">
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-[#0F74BA] to-[#0a5a91] text-white py-24 lg:py-32 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 right-10 w-64 h-64 rounded-full bg-white"></div>
      <div class="absolute bottom-10 left-10 w-48 h-48 rounded-full bg-[#8DC740]"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          專業整合<br />
          <span class="text-[#8DC740]">科技服務</span>首選
        </h1>
        <p class="text-lg sm:text-xl text-blue-100 mb-8 leading-relaxed">
          沃原科技提供網路佈線、監控系統、門禁管理、電力工程等企業級整合服務，
          協助您建構安全可靠的科技基礎設施。
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/contact-us"
            class="px-8 py-3.5 bg-[#F2830A] text-white font-semibold rounded-full hover:bg-orange-600 transition-colors shadow-lg"
          >
            免費諮詢
          </a>
          <a
            href="/services"
            class="px-8 py-3.5 bg-white/20 backdrop-blur text-white font-semibold rounded-full hover:bg-white/30 transition-colors border border-white/30"
          >
            了解服務
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900">我們的服務</h2>
        <p class="text-gray-500 mt-3">一站式科技整合解決方案</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/integrate" class="group bg-white rounded-2xl p-6 shadow-sm hover:shadow-md transition-all border border-gray-100 hover:border-[#0F74BA]">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-[#0F74BA] transition-colors">
            <svg class="w-6 h-6 text-[#0F74BA] group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2 group-hover:text-[#0F74BA] transition-colors">專業整合</h3>
          <p class="text-sm text-gray-500">系統整合規劃與建置，打造完整的企業科技環境</p>
        </a>
        <a href="/internet" class="group bg-white rounded-2xl p-6 shadow-sm hover:shadow-md transition-all border border-gray-100 hover:border-[#0F74BA]">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-[#0F74BA] transition-colors">
            <svg class="w-6 h-6 text-[#0F74BA] group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2 group-hover:text-[#0F74BA] transition-colors">網路服務</h3>
          <p class="text-sm text-gray-500">網路佈線、光纖建置、無線網路規劃與安裝</p>
        </a>
        <a href="/media" class="group bg-white rounded-2xl p-6 shadow-sm hover:shadow-md transition-all border border-gray-100 hover:border-[#0F74BA]">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-[#0F74BA] transition-colors">
            <svg class="w-6 h-6 text-[#0F74BA] group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2 group-hover:text-[#0F74BA] transition-colors">通訊多媒體</h3>
          <p class="text-sm text-gray-500">監視系統、門禁管理、視訊會議設備整合</p>
        </a>
        <a href="/electric" class="group bg-white rounded-2xl p-6 shadow-sm hover:shadow-md transition-all border border-gray-100 hover:border-[#0F74BA]">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-[#0F74BA] transition-colors">
            <svg class="w-6 h-6 text-[#0F74BA] group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2 group-hover:text-[#0F74BA] transition-colors">電力工程</h3>
          <p class="text-sm text-gray-500">UPS 不斷電系統、配電規劃、電力品質提升</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Us -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">為什麼選擇沃原科技？</h2>
          <div class="space-y-5">
            {[
              { icon: '🏆', title: '豐富經驗', desc: '百項以上工程專案完成，深厚的產業實戰經驗' },
              { icon: '🔧', title: '一站整合', desc: '網路、通訊、電力全方位服務，一個窗口解決所有需求' },
              { icon: '🛡️', title: '品質保證', desc: '嚴格施工標準，確保系統穩定可靠，長期運行無憂' },
              { icon: '📞', title: '售後支援', desc: '完善的技術支援團隊，協助您解決任何技術問題' },
            ].map(item => (
              <div class="flex gap-4">
                <div class="text-2xl flex-shrink-0">{item.icon}</div>
                <div>
                  <h3 class="font-semibold text-gray-900">{item.title}</h3>
                  <p class="text-gray-500 text-sm mt-0.5">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="bg-gradient-to-br from-[#0F74BA] to-[#0a5a91] rounded-2xl p-8 text-white">
          <div class="grid grid-cols-2 gap-6">
            {[
              { num: '100+', label: '完成專案' },
              { num: '10+', label: '服務年資' },
              { num: '500+', label: '服務客戶' },
              { num: '24h', label: '技術支援' },
            ].map(stat => (
              <div class="text-center">
                <div class="text-4xl font-bold text-[#8DC740]">{stat.num}</div>
                <div class="text-blue-100 text-sm mt-1">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Posts -->
  {recentPosts.length > 0 && (
    <section class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-10">
          <div>
            <h2 class="text-3xl font-bold text-gray-900">最新消息</h2>
            <p class="text-gray-500 mt-1">掌握沃原動態與產業資訊</p>
          </div>
          <a href="/our-blog" class="text-[#0F74BA] font-medium hover:underline text-sm hidden sm:block">
            查看全部 →
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {recentPosts.map((post) => (
            <article class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
              {post.data.image && (
                <a href={postUrl(post)}>
                  <img src={post.data.image} alt={post.data.title} class="w-full h-44 object-cover" />
                </a>
              )}
              <div class="p-5">
                <time class="text-xs text-gray-400">
                  {post.data.date.toLocaleDateString('zh-TW', { year: 'numeric', month: '2-digit', day: '2-digit' })}
                </time>
                <h3 class="font-semibold text-gray-900 mt-2 mb-2 line-clamp-2">
                  <a href={postUrl(post)} class="hover:text-[#0F74BA] transition-colors">{post.data.title}</a>
                </h3>
                {post.data.description && (
                  <p class="text-sm text-gray-500 line-clamp-2">{post.data.description}</p>
                )}
              </div>
            </article>
          ))}
        </div>
        <div class="text-center mt-8 sm:hidden">
          <a href="/our-blog" class="text-[#0F74BA] font-medium hover:underline text-sm">查看全部 →</a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-20 bg-[#0F74BA]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <h2 class="text-3xl font-bold mb-4">準備好開始您的專案了嗎？</h2>
      <p class="text-blue-100 mb-8 max-w-xl mx-auto">
        聯絡沃原科技，讓我們的專業團隊為您規劃最適合的整合方案。
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/contact-us"
          class="px-8 py-3.5 bg-[#F2830A] text-white font-semibold rounded-full hover:bg-orange-600 transition-colors shadow-lg"
        >
          立即聯絡
        </a>
        <a
          href="/about-us"
          class="px-8 py-3.5 bg-white/20 text-white font-semibold rounded-full hover:bg-white/30 transition-colors border border-white/30"
        >
          認識沃原
        </a>
      </div>
    </div>
  </section>
</Layout>
