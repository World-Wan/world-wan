---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = '沃原科技提供專業整合、網路服務、通訊多媒體、電力工程等全方位科技服務。', image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    {image && <meta property="og:image" content={image} />}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet" />
    <title>{title} | 沃原科技</title>
  </head>
  <body class="flex flex-col min-h-screen">
    <!-- Header -->
    <header class="bg-white shadow-sm sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 lg:h-20">
          <!-- Logo -->
          <a href="/" class="flex-shrink-0">
            <img
              src="/logo.png"
              alt="沃原科技"
              class="h-10 lg:h-12 w-auto"
              width="300"
              height="51"
            />
          </a>

          <!-- Desktop Nav -->
          <nav class="hidden lg:flex items-center gap-1">
            <a href="/" class="nav-link">首頁</a>
            <a href="/about-us" class="nav-link">關於沃原</a>

            <!-- Services Dropdown -->
            <div class="relative group">
              <a href="/services" class="nav-link flex items-center gap-1">
                服務項目
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
              <div class="absolute top-full left-0 w-40 bg-white shadow-lg rounded-b-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-10">
                <a href="/integrate" class="block px-4 py-3 text-sm text-gray-700 hover:bg-blue-50 hover:text-[#0F74BA]">專業整合</a>
                <a href="/internet" class="block px-4 py-3 text-sm text-gray-700 hover:bg-blue-50 hover:text-[#0F74BA]">網路服務</a>
                <a href="/media" class="block px-4 py-3 text-sm text-gray-700 hover:bg-blue-50 hover:text-[#0F74BA]">通訊多媒體</a>
                <a href="/electric" class="block px-4 py-3 text-sm text-gray-700 hover:bg-blue-50 hover:text-[#0F74BA]">電力工程</a>
              </div>
            </div>

            <a href="/our-blog" class="nav-link">最新消息</a>
            <a href="/contact-us" class="px-5 py-2 bg-[#F2830A] text-white rounded-full font-medium hover:bg-orange-600 transition-colors text-sm">聯絡我們</a>
          </nav>

          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-md text-gray-600 hover:text-[#0F74BA]" aria-label="開啟選單">
            <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- Mobile Nav -->
        <div id="mobile-menu" class="lg:hidden hidden border-t border-gray-100 py-3">
          <a href="/" class="mobile-nav-link">首頁</a>
          <a href="/about-us" class="mobile-nav-link">關於沃原</a>
          <a href="/services" class="mobile-nav-link">服務項目</a>
          <a href="/integrate" class="mobile-nav-link pl-8 text-gray-500">⌙ 專業整合</a>
          <a href="/internet" class="mobile-nav-link pl-8 text-gray-500">⌙ 網路服務</a>
          <a href="/media" class="mobile-nav-link pl-8 text-gray-500">⌙ 通訊多媒體</a>
          <a href="/electric" class="mobile-nav-link pl-8 text-gray-500">⌙ 電力工程</a>
          <a href="/our-blog" class="mobile-nav-link">最新消息</a>
          <a href="/contact-us" class="mobile-nav-link text-[#F2830A] font-medium">聯絡我們</a>
        </div>
      </div>
    </header>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-300 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Company Info -->
          <div>
            <img
              src="/logo.png"
              alt="沃原科技"
              class="h-10 w-auto mb-4 brightness-0 invert"
              width="300"
              height="51"
            />
            <p class="text-sm leading-relaxed text-gray-400">
              沃原科技有限公司<br />
              統一編號：94206722<br />
              提供企業級網路、通訊、電力全方位整合服務。
            </p>
            <a
              href="https://www.facebook.com/profile.php?id=61552246295157"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 mt-4 text-[#8DC740] hover:text-green-400 transition-colors text-sm"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
              Facebook
            </a>
          </div>

          <!-- Services -->
          <div>
            <h3 class="text-white font-semibold mb-4">服務項目</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/integrate" class="hover:text-white transition-colors">專業整合</a></li>
              <li><a href="/internet" class="hover:text-white transition-colors">網路服務</a></li>
              <li><a href="/media" class="hover:text-white transition-colors">通訊多媒體</a></li>
              <li><a href="/electric" class="hover:text-white transition-colors">電力工程</a></li>
            </ul>
          </div>

          <!-- Contact -->
          <div>
            <h3 class="text-white font-semibold mb-4">聯絡資訊</h3>
            <ul class="space-y-2 text-sm text-gray-400">
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-[#0F74BA]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                台中市西區臺灣大道二段285號4樓之2
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 flex-shrink-0 text-[#0F74BA]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <a href="tel:0423210735" class="hover:text-white">(04)2321-0735</a>
                ／
                <a href="tel:0423210734" class="hover:text-white">(04)2321-0734</a>
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 flex-shrink-0 text-[#0F74BA]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <a href="mailto:Service@world-wan.com.tw" class="hover:text-white">Service@world-wan.com.tw</a>
              </li>
            </ul>
          </div>
        </div>

        <div class="border-t border-gray-800 mt-8 pt-8 text-center text-sm text-gray-500">
          © {new Date().getFullYear()} 沃原科技有限公司 All rights reserved.
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');
      const closeIcon = document.getElementById('close-icon');

      btn?.addEventListener('click', () => {
        const isOpen = !menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden', isOpen);
        menuIcon?.classList.toggle('hidden', !isOpen);
        closeIcon?.classList.toggle('hidden', isOpen);
      });
    </script>

    <style>
      @reference "../styles/global.css";
      .nav-link {
        @apply px-4 py-2 text-sm font-medium text-gray-700 hover:text-[#0F74BA] transition-colors rounded-md;
      }
      .mobile-nav-link {
        @apply block px-4 py-3 text-sm font-medium text-gray-700 hover:text-[#0F74BA] hover:bg-blue-50 rounded-md;
      }
    </style>
  </body>
</html>
